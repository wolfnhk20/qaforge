# ===================================================
# Functional Contract Auditor — Environment Variables
# ===================================================
# Copy this file to .env and fill in your values:
#   copy .env.example .env
# ===================================================

# REQUIRED — Groq API key (get from https://console.groq.com/keys)
GROQ_API_KEY=gsk_paste_your_key_here

# REQUIRED — GitHub token (get from https://github.com/settings/tokens)
# Needs 'repo' scope for issue filing, 'public_repo' for read-only
GITHUB_TOKEN=ghp_paste_your_token_here

# REQUIRED — Base URL of the API server to test against
# Agent 4 sends real HTTP requests here
# Set to your staging/dev server, or http://localhost:PORT
STAGING_BASE_URL=http://localhost:5000

# REQUIRED FOR PERSISTENCE — Supabase project URL and service role key
# Used by the FastAPI API layer to persist completed audits and logs
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# OPTIONAL — Override the LLM model (default: openai/gpt-oss-120b)
# MODEL_NAME=openai/gpt-oss-120b

# OPTIONAL — Override default branch (default: main)
# DEFAULT_BRANCH=main
